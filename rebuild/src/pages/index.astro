---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/shell/PageShell.astro';

import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import Featured from '../components/sections/Featured.astro';
import Services from '../components/sections/Services.astro';
import VideoStrip from '../components/sections/VideoStrip.astro';
import Portfolio from '../components/sections/Portfolio.astro';
import ProcessCarousel from '../components/sections/ProcessCarousel.astro';
import TeamGrid from '../components/sections/TeamGrid.astro';
import CtaStrip from '../components/sections/CtaStrip.astro';
import BlogPreview from '../components/sections/BlogPreview.astro';
import Subscribe from '../components/sections/Subscribe.astro';
import Pricing from '../components/sections/Pricing.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import LogoCloud from '../components/sections/LogoCloud.astro';
import Contact from '../components/sections/Contact.astro';

import {
  meta,
  hero,
  about,
  featured,
  services,
  videoStrip,
  portfolio,
  process,
  team,
  stats,
  blog,
  pricing,
  testimonials,
  logos,
  contact,
} from '../data/index';
---

<BaseLayout title={meta.title} description={meta.description}>
  <PageShell brand={meta.brand} navVariant="transparent-white">
    <Hero {...hero} />
    <About {...about} />
    <Featured items={featured} />
    <Services items={services} />
    <VideoStrip {...videoStrip} />
    <Portfolio items={portfolio} />
    <ProcessCarousel steps={process} />
    <TeamGrid members={team} />
    <CtaStrip stats={stats} />
    <BlogPreview posts={blog} />
    <Subscribe />
    <Pricing plans={pricing} />
    <Testimonials quotes={testimonials} />
    <LogoCloud rows={logos} />
    <Contact {...contact} />
  </PageShell>
</BaseLayout>
