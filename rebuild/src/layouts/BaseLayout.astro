---
import '../styles/fonts.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  theme?: 'default' | 'blue' | 'purple-pink' | 'magenta';
  bodyClass?: string;
}

const {
  title = 'Infinito',
  description = 'Infinito — modern creative agency & portfolio template.',
  theme,
  bodyClass = '',
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {/* Boot: decide synchronously whether to hide [data-anim] elements
        before they paint. With JS + no reduced motion, add `has-anim`
        so CSS hides them; otherwise leave them visible. */}
    <script is:inline>
      (function () {
        try {
          var reduced = window.matchMedia(
            '(prefers-reduced-motion: reduce)'
          ).matches;
          if (!reduced) document.documentElement.classList.add('has-anim');
        } catch (_) {}
      })();
    </script>
  </head>
  <body class={bodyClass}>
    <slot />

    <script>
      import { mount } from '../lib/animations';

      const start = () => mount();
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', start, { once: true });
      } else {
        start();
      }
    </script>
  </body>
</html>
