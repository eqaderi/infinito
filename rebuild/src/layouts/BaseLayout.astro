---
import '../styles/fonts.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  theme?: 'default' | 'blue' | 'purple-pink' | 'magenta';
  bodyClass?: string;
  /* Above-the-fold image(s) to preload — typically the hero background, which
     is the LCP element. Keeps the largest paint off the lazy path. */
  preloadImages?: string[];
}

const {
  title = 'Infinito',
  description = 'Infinito — modern creative agency & portfolio template.',
  theme,
  bodyClass = '',
  preloadImages = [],
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {
      preloadImages.map((href) => (
        <link rel="preload" as="image" href={href} fetchpriority="high" />
      ))
    }
    <title>{title}</title>
    {/* Boot: decide synchronously whether to hide [data-anim] elements
        before they paint. With JS + no reduced motion, add `has-anim`
        so CSS hides them; otherwise leave them visible. */}
    <script is:inline>
      (function () {
        try {
          var reduced = window.matchMedia(
            '(prefers-reduced-motion: reduce)'
          ).matches;
          if (!reduced) document.documentElement.classList.add('has-anim');
        } catch (_) {}
      })();
    </script>
  </head>
  <body class={bodyClass}>
    <slot />

    <script>
      import { mount } from '../lib/animations';
      import { mountCarousels } from '../lib/carousels';
      import { mountLightbox } from '../lib/lightbox';

      // Yield to the first paint before booting GSAP: requestIdleCallback when
      // available (capped so intros still fire promptly), else a microtask via
      // rAF. Triggered on DOM-ready, not load, so intro animations aren't
      // gated behind image loading. mountCarousels/mountLightbox run regardless
      // of reduced motion — they're navigation, not decorative motion (the
      // lightbox lazy-loads its core only when an item is opened).
      const interactive = () => {
        mount();
        mountCarousels();
        mountLightbox();
      };
      const boot = () => {
        if ('requestIdleCallback' in window) {
          requestIdleCallback(interactive, { timeout: 200 });
        } else {
          requestAnimationFrame(interactive);
        }
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', boot, { once: true });
      } else {
        boot();
      }
    </script>
  </body>
</html>
