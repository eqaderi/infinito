---

<svg
  class={className}
  viewBox="0 0 560 315"
  aria-hidden="true"
  data-anim="svg-draw"
  data-anim-fill
  data-anim-duration="1.6"
>
  {
    d ? (
      <path
        d={d}
        fill-rule="evenodd"
        vector-effect="non-scaling-stroke"
        class="fill-paper-gray stroke-paper-gray [stroke-width:1px]"
      />
    ) : (
      /* Unknown number: no glyph asset — degrade to solid text like the
       * legacy span did, rather than rendering nothing. */
      <text
        x="50%"
        y="80%"
        text-anchor="middle"
        class="fill-paper-gray font-display [font-size:300px]"
      >
        {number}
      </text>
    )
  }
</svg>
