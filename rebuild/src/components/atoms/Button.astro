---
interface Props {
  variant?: 'gradient-solid' | 'gradient-text' | 'gradient-outline' | 'dark' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: unknown;
}

const {
  variant = 'gradient-solid',
  size = 'md',
  href,
  type = 'button',
  class: className = '',
  ...rest
} = Astro.props;

const sizeMap = {
  sm: 'px-5 py-2 text-xs',
  md: 'px-7 py-3 text-sm',
  lg: 'px-10 py-4 text-base',
} as const;

const base =
  'inline-flex items-center justify-center gap-2 rounded-full font-ui font-medium uppercase tracking-[0.18em] transition-transform duration-300 ease-out-back hover:-translate-y-0.5 focus-visible:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-text focus-visible:ring-offset-2';

const variantClasses: Record<NonNullable<Props['variant']>, string> = {
  'gradient-solid': 'text-paper bg-gradient-accent shadow-sm hover:shadow-md',
  'gradient-text':
    'border border-paper-gray bg-paper hover:border-transparent',
  'gradient-outline':
    'relative text-ink bg-paper border-[2px] border-transparent [background-image:linear-gradient(var(--tw-bg-paper,white),var(--tw-bg-paper,white)),linear-gradient(45deg,var(--accent-from),var(--accent-to))] [background-origin:border-box] [background-clip:padding-box,border-box]',
  dark: 'text-paper bg-ink hover:bg-ink-soft',
  ghost: 'text-ink hover:text-accent-text',
};

const cls = [base, sizeMap[size], variantClasses[variant], className]
  .filter(Boolean)
  .join(' ');

const Tag = href ? 'a' : 'button';
---

{
  href ? (
    <a href={href} class={cls} {...rest}>
      {variant === 'gradient-text' ? (
        <span class="text-gradient">
          <slot />
        </span>
      ) : (
        <slot />
      )}
    </a>
  ) : (
    <button type={type} class={cls} {...rest}>
      {variant === 'gradient-text' ? (
        <span class="text-gradient">
          <slot />
        </span>
      ) : (
        <slot />
      )}
    </button>
  )
}
