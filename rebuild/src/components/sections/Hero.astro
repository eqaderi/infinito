---
interface Props {
  title?: string;
  subtitle?: string;
  background?: string;
  scrollTarget?: string;
}

const {
  title = 'Denouement.',
  subtitle = 'The resolution of a mystery',
  background = '/img/backgrounds/hero.jpg',
  scrollTarget = '#about',
} = Astro.props;
---

<header
  id="hero"
  class="relative grid min-h-screen place-items-center overflow-hidden bg-ink text-paper"
>
  {/* Background */}
  <div class="absolute inset-0">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style={`background-image: url('${background}');`}
      data-anim="intro-fade"
    ></div>
    <div class="absolute inset-0 bg-linear-to-b from-ink/70 via-ink/40 to-ink/80"></div>
  </div>

  {/* Content */}
  <div class="relative z-[1] px-6 text-center nav:px-12">
    <div class="overflow-hidden">
      <h1
        class="font-display text-6xl leading-[0.95] nav:text-8xl lg:text-[10rem]"
        data-anim="intro-up"
        data-anim-delay="0.2"
      >
        {title}
      </h1>
    </div>
    <div class="mt-6 overflow-hidden">
      <p
        class="font-ui text-sm uppercase tracking-[0.4em] text-paper/85"
        data-anim="intro-up"
        data-anim-delay="0.5"
      >
        {subtitle}
      </p>
    </div>
  </div>

  {/* Scroll-down */}
  <a
    href={scrollTarget}
    class="absolute bottom-10 left-1/2 z-[1] flex -translate-x-1/2 flex-col items-center gap-3 text-paper/70 transition-colors hover:text-paper"
    data-anim="intro-up"
    data-anim-delay="0.9"
    aria-label="Scroll to next section"
  >
    <span class="font-ui text-[10px] uppercase tracking-[0.4em]">Scroll down</span>
    <span class="relative inline-block h-12 w-px overflow-hidden bg-paper/30">
      <span class="absolute inset-x-0 -top-12 h-12 animate-[scroll-cue_1.6s_ease-in-out_infinite] bg-paper"></span>
    </span>
  </a>

  <style>
    @keyframes scroll-cue {
      0% { transform: translateY(0); }
      100% { transform: translateY(150%); }
    }
  </style>
</header>
