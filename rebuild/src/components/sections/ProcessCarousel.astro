---
import SectionTitle from '../atoms/SectionTitle.astro';

export interface ProcessStep {
  label: string;
  position: number; // 0..1 along the timeline
  body: string;
  bodyRight?: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  steps?: ProcessStep[];
}

const {
  eyebrow = 'the history lesson',
  title = 'we did grow over the years',
  steps = [
    {
      label: '1997: Est.',
      position: 0,
      body: 'Quam impedit nisi aliquid veritatis praesentium nesciunt a quia cupiditate repellat doloribus! Illum doloribus, odit consequatur sed minima eius earum qui, corrupti.',
      bodyRight:
        'Sed minima eius earum qui, corrupti. Maiores amet digni nisi autem quia ipsum non sint enim pariatur porro sunt totam nobis. Explicabo quo aut provident.',
    },
    {
      label: '2001: growing',
      position: 0.18,
      body: 'Quam impedit nisi aliquid veritatis praesentium nesciunt a quia cupiditate repellat doloribus! Illum doloribus, odit consequatur sed minima eius earum qui, corrupti.',
      bodyRight:
        'Sed minima eius earum qui, corrupti. Maiores amet digni nisi autem quia ipsum non sint enim pariatur porro sunt totam nobis. Explicabo quo aut provident.',
    },
    {
      label: '2006: reputation',
      position: 0.53,
      body: 'Quam impedit nisi aliquid veritatis praesentium nesciunt a quia cupiditate repellat doloribus! Illum doloribus, odit consequatur sed minima eius earum qui, corrupti.',
      bodyRight:
        'Sed minima eius earum qui, corrupti. Maiores amet digni nisi autem quia ipsum non sint enim pariatur porro sunt totam nobis. Explicabo quo aut provident.',
    },
    {
      label: '2018: success',
      position: 1,
      body: 'Quam impedit nisi aliquid veritatis praesentium nesciunt a quia cupiditate repellat doloribus! Illum doloribus, odit consequatur sed minima eius earum qui, corrupti.',
      bodyRight:
        'Sed minima eius earum qui, corrupti. Maiores amet digni nisi autem quia ipsum non sint enim pariatur porro sunt totam nobis. Explicabo quo aut provident.',
    },
  ],
} = Astro.props;

const stepsJson = JSON.stringify(steps);
---

<section
  class="bg-ink px-6 py-24 text-paper nav:px-12 nav:py-32"
  x-data={`{
    active: 0,
    count: ${steps.length},
    steps: ${stepsJson},
    progress() {
      if (this.count <= 1) return 0;
      return (this.active / (this.count - 1)) * 100;
    }
  }`}
>
  <div class="mx-auto max-w-[1100px]">
    <div class="mx-auto mb-16 max-w-2xl text-center">
      <p
        class="mb-3 font-ui text-xs uppercase tracking-[0.32em] text-paper/60"
        data-anim="slide-up"
      >
        {eyebrow}
      </p>
      <h2
        class="font-display text-3xl leading-[1.15] nav:text-5xl"
        data-anim="slide-up"
        data-anim-delay="0.15"
      >
        {title}
      </h2>
    </div>

    {/* Timeline — line is positioned to start/end at the dot centers */}
    <div class="relative mx-auto mb-16 max-w-3xl px-1.5" data-anim="fade-up">
      {/* Track + fill (offset by half a dot so they hit dot centers) */}
      <div class="pointer-events-none absolute inset-x-1.5 top-1/2 h-px -translate-y-1/2 bg-paper/15"></div>
      <div
        class="pointer-events-none absolute left-1.5 top-1/2 h-px -translate-y-1/2 bg-gradient-accent transition-all duration-500 ease-out"
        :style="`width: calc((100% - 0.75rem) * ${progress()} / 100)`"
      ></div>

      <ul class="relative -mx-1.5 flex justify-between">
        {
          steps.map((step, idx) => (
            <li class="flex">
              <button
                type="button"
                class="group flex flex-col items-center px-3 py-2 transition-colors"
                @click={`active = ${idx}`}
                aria-label={step.label}
              >
                <span
                  class="block h-3 w-3 rounded-full transition-all duration-300 group-hover:scale-125"
                  :class={`active >= ${idx} ? 'bg-paper scale-110' : 'bg-paper/30 group-hover:bg-paper/60'`}
                ></span>
                <span
                  class="mt-3 whitespace-nowrap font-ui text-[10px] uppercase tracking-[0.18em] transition-colors group-hover:text-paper"
                  :class={`active === ${idx} ? 'text-paper' : 'text-paper/50'`}
                >
                  {step.label}
                </span>
              </button>
            </li>
          ))
        }
      </ul>
    </div>

    {/* Slides */}
    <div class="relative min-h-[160px]">
      {
        steps.map((step, idx) => (
          <div
            class="absolute inset-0 grid gap-10 transition-opacity duration-500 nav:grid-cols-2"
            x-show={`active === ${idx}`}
            x-transition.opacity.duration.500ms
          >
            <p class="font-body text-base leading-relaxed text-paper/85">
              {step.body}
            </p>
            {step.bodyRight && (
              <p class="font-body text-base leading-relaxed text-paper/85">
                {step.bodyRight}
              </p>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
