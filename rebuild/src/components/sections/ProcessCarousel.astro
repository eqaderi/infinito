---
import SectionTitle from '../atoms/SectionTitle.astro';

export interface ProcessStep {
  label: string;
  position: number; // 0..1 along the timeline
  body: string;
  bodyRight?: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  steps?: ProcessStep[];
}

const {
  eyebrow = 'the history lesson',
  title = 'we did grow over the years',
  steps = [
    {
      label: '1997: Est.',
      position: 0,
      body: 'Quam impedit nisi aliquid veritatis praesentium nesciunt a quia cupiditate repellat doloribus! Illum doloribus, odit consequatur sed minima eius earum qui, corrupti.',
      bodyRight:
        'Sed minima eius earum qui, corrupti. Maiores amet digni nisi autem quia ipsum non sint enim pariatur porro sunt totam nobis. Explicabo quo aut provident.',
    },
    {
      label: '2001: growing',
      position: 0.18,
      body: 'Quam impedit nisi aliquid veritatis praesentium nesciunt a quia cupiditate repellat doloribus! Illum doloribus, odit consequatur sed minima eius earum qui, corrupti.',
      bodyRight:
        'Sed minima eius earum qui, corrupti. Maiores amet digni nisi autem quia ipsum non sint enim pariatur porro sunt totam nobis. Explicabo quo aut provident.',
    },
    {
      label: '2006: reputation',
      position: 0.53,
      body: 'Quam impedit nisi aliquid veritatis praesentium nesciunt a quia cupiditate repellat doloribus! Illum doloribus, odit consequatur sed minima eius earum qui, corrupti.',
      bodyRight:
        'Sed minima eius earum qui, corrupti. Maiores amet digni nisi autem quia ipsum non sint enim pariatur porro sunt totam nobis. Explicabo quo aut provident.',
    },
    {
      label: '2018: success',
      position: 1,
      body: 'Quam impedit nisi aliquid veritatis praesentium nesciunt a quia cupiditate repellat doloribus! Illum doloribus, odit consequatur sed minima eius earum qui, corrupti.',
      bodyRight:
        'Sed minima eius earum qui, corrupti. Maiores amet digni nisi autem quia ipsum non sint enim pariatur porro sunt totam nobis. Explicabo quo aut provident.',
    },
  ],
} = Astro.props;

---

<section class="bg-ink px-6 py-24 text-paper nav:px-12 nav:py-32" data-process>
  <div class="mx-auto max-w-[1100px]">
    <div class="mx-auto mb-16 max-w-2xl text-center">
      <p
        class="mb-3 font-ui text-xs uppercase tracking-[0.32em] text-paper/60"
        data-anim="slide-up"
      >
        {eyebrow}
      </p>
      <h2
        class="font-display text-3xl leading-[1.15] nav:text-5xl"
        data-anim="slide-up"
        data-anim-delay="0.15"
      >
        {title}
      </h2>
    </div>

    {/* Timeline — line is positioned to start/end at the dot centers */}
    <div class="relative mx-auto mb-16 max-w-3xl px-1.5" data-anim="fade-up">
      {/* Track + fill (offset by half a dot so they hit dot centers) */}
      <div class="pointer-events-none absolute inset-x-1.5 top-1/2 h-px -translate-y-1/2 bg-paper/15"></div>
      <div
        class="process-progress pointer-events-none absolute left-1.5 top-1/2 h-px -translate-y-1/2 bg-gradient-accent transition-all duration-500 ease-out"
        data-progress-fill
        style="width: 0"
      ></div>

      <ul class="relative -mx-1.5 flex justify-between">
        {
          steps.map((step) => (
            <li class="flex">
              <button
                type="button"
                class="group flex flex-col items-center px-3 py-2"
                data-step
                aria-label={step.label}
              >
                <span
                  class="process-dot block h-3 w-3 rounded-full transition-all duration-300 group-hover:scale-125"
                  data-dot
                />
                <span
                  class="process-label mt-3 whitespace-nowrap font-ui text-[10px] uppercase tracking-[0.18em] transition-colors group-hover:text-paper"
                  data-label
                >
                  {step.label}
                </span>
              </button>
            </li>
          ))
        }
      </ul>
    </div>

    {/* Slides */}
    <div class="swiper relative min-h-[160px]" data-process-slider>
      <div class="swiper-wrapper">
        {
          steps.map((step) => (
            <div class="swiper-slide" data-step-panel>
              <div class="grid gap-10 nav:grid-cols-2">
                <p class="font-body text-base leading-relaxed text-paper/85">
                  {step.body}
                </p>
                {step.bodyRight && (
                  <p class="font-body text-base leading-relaxed text-paper/85">
                    {step.bodyRight}
                  </p>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Before Swiper boots, slides sit stacked in normal flow — show only the
     first to avoid a flash of all panels at once. */
  [data-process-slider]:not(.swiper-initialized) .swiper-slide:not(:first-child) {
    display: none;
  }

  /* Timeline state, driven by data-* attributes toggled in carousels.ts.
     Kept in CSS (not Tailwind :class) since there's no Alpine reactivity now. */
  [data-process] [data-dot] {
    background: color-mix(in srgb, var(--color-paper) 30%, transparent);
  }
  [data-process] [data-step]:hover [data-dot]:not([data-filled]) {
    background: color-mix(in srgb, var(--color-paper) 60%, transparent);
  }
  [data-process] [data-dot][data-filled] {
    background: var(--color-paper);
    transform: scale(1.1);
  }
  [data-process] [data-label] {
    color: color-mix(in srgb, var(--color-paper) 50%, transparent);
  }
  [data-process] [data-label][data-active] {
    color: var(--color-paper);
  }
</style>
