const {
  eyebrow = 'the team',
  title = 'Meet our talents & experts',
  body = 'The work is as important as the pleasure we get from doing it. When people who love creating, learning and growing get together, forming a team with ties that transcend the workplace.',
  ctaLabel = 'get to know us even better!',
  ctaHref = '#0',
  members = [
    {
      name: 'John Conley',
      role: 'Front-end Developer',
      image: '/img/team/john.jpg',
      social: [
        { label: 'Twitter', href: '#0', icon: ICON.twitter },
        { label: 'Stack Overflow', href: '#0', icon: ICON.stackoverflow },
        { label: 'Vimeo', href: '#0', icon: ICON.vimeo },
      ],
    },
    {
      name: 'Rebeca Jones',
      role: 'President + Creative Director',
      image: '/img/team/rebeca.jpg',
      social: [
        { label: 'Instagram', href: '#0', icon: ICON.instagram },
        { label: 'Google', href: '#0', icon: ICON.google },
      ],
    },
    {
      name: 'Stephen Dorff',
      role: 'Project Manager',
      image: '/img/team/stephen.jpg',
      social: [
        { label: 'GitHub', href: '#0', icon: ICON.github },
        { label: 'Facebook', href: '#0', icon: ICON.facebook },
        { label: 'CodePen', href: '#0', icon: ICON.codepen },
      ],
    },
  ],
} = Astro.props;
---

<section id="team" class="bg-paper px-6 py-24 nav:px-12 nav:py-32">
  <div class="mx-auto max-w-[1200px]">
    <div class="mb-16 grid gap-10 md:grid-cols-12 md:items-end">
      <div class="md:col-span-6">
        <SectionTitle eyebrow={eyebrow} title={title} />
      </div>
      <div class="md:col-span-5 md:col-start-8">
        <p
          class="font-body text-lg leading-relaxed text-ink-soft"
          data-anim="slide-up"
          data-anim-delay="0.2"
        >
          {body}
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3">
      {
        members.map((m, idx) => (
          <div
            class="group relative overflow-hidden bg-paper-gray"
            data-anim="slide-up"
            data-anim-delay={(idx * 0.1).toFixed(2)}
          >
            <div class="aspect-[4/5] overflow-hidden">
              <img
                src={m.image}
                alt={m.name}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/30 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
            <div class="absolute bottom-0 left-0 p-6 text-paper opacity-0 transition-all duration-500 group-hover:opacity-100">
              <h3 class="font-display text-2xl">{m.name}</h3>
              <p class="mt-1 font-ui text-xs uppercase tracking-[0.18em] text-paper/80">
                {m.role}
              </p>
            </div>
            {m.social && (
              <div class="absolute right-4 top-4 flex translate-y-2 flex-col gap-2 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
                {m.social.map((s) => (
                  <a
                    href={s.href}
                    aria-label={s.label}
                    class="grid h-9 w-9 place-items-center rounded-full bg-paper/15 text-paper backdrop-blur transition-colors hover:bg-gradient-accent"
                  >
                    <svg
                      class="h-4 w-4"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d={s.icon} />
                    </svg>
                  </a>
                ))}
              </div>
            )}
          </div>
        ))
      }
    </div>

    <div class="mt-16 text-center" data-anim="rotate-in">
      <Button href={ctaHref} variant="gradient-outline" size="lg">
        {ctaLabel}
      </Button>
    </div>
  </div>
</section>
