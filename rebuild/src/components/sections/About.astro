---
import Button from '../atoms/Button.astro';

interface Props {
  eyebrow?: string;
  title?: string;
  body?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  eyebrow = 'Est. 2018',
  title = 'Infinito; The ultimate theme',
  body = 'We design award-winning, functional, and beautiful web sites. Our designers craft a User Experience with web sites that are both technically compliant and aesthetically perfect.',
  ctaLabel = 'see our works',
  ctaHref = '#portfolio',
} = Astro.props;
---

<section
  id="about"
  class="bg-paper-soft px-6 py-24 text-center nav:px-12 nav:py-32"
>
  <div class="mx-auto max-w-3xl">
    <p
      class="mb-4 font-ui text-xs uppercase tracking-[0.32em] text-ink-muted"
      data-anim="slide-up"
    >
      {eyebrow}
    </p>
    <h2
      class="font-display text-4xl leading-[1.15] text-ink nav:text-6xl"
      data-anim="slide-up"
      data-anim-delay="0.15"
    >
      {title}
    </h2>
    <p
      class="mx-auto mt-8 max-w-2xl font-body text-lg leading-relaxed text-ink-soft"
      data-anim="slide-up"
      data-anim-delay="0.3"
    >
      {body}
    </p>
    <div class="mt-12" data-anim="rotate-in" data-anim-delay="0.5">
      <Button href={ctaHref} variant="gradient-solid" size="lg">
        {ctaLabel}
      </Button>
    </div>
  </div>
</section>
