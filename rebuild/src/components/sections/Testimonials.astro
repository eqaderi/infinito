---
export interface Quote {
  quote: string;
  author: string;
  role: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  quotes?: Quote[];
}

const {
  eyebrow = 'testimonials',
  title = 'what people say!',
  quotes = [
    {
      quote:
        'Balanced between ease of use and power features to hire effectively, it provides a great applicant experience.',
      author: 'Justin Ronaldo',
      role: 'Talent Unit',
    },
    {
      quote:
        "Everyone I've worked with, from my account manager to technical support, has proven they really care about my success.",
      author: 'James Mattis',
      role: 'US Marines',
    },
    {
      quote:
        'Infinito has given us a simple way to reach tons of job seekers and a quick process to quickly filter through them for the best candidates.',
      author: 'Tess Brighton',
      role: 'Clomedia Group Inc.',
    },
  ],
} = Astro.props;
---

<section
  class="bg-paper-soft px-6 py-24 nav:px-12 nav:py-32"
  x-data={`{
    active: 0,
    count: ${quotes.length},
    next() { this.active = (this.active + 1) % this.count },
    prev() { this.active = (this.active - 1 + this.count) % this.count }
  }`}
>
  <div class="mx-auto max-w-3xl">
    <header class="mb-12 text-center">
      <p
        class="mb-3 font-ui text-xs uppercase tracking-[0.32em] text-ink-muted"
        data-anim="slide-up"
      >
        {eyebrow}
      </p>
      <h2
        class="font-display text-4xl text-ink nav:text-5xl"
        data-anim="slide-up"
        data-anim-delay="0.15"
      >
        {title}
      </h2>
    </header>

    {/* Big background quote glyph */}
    <div class="relative px-4 text-center">
      <span
        class="pointer-events-none absolute left-1/2 top-1/2 z-0 -translate-x-1/2 -translate-y-1/2 select-none font-display text-[16rem] leading-none text-paper-gray nav:text-[22rem]"
        aria-hidden="true"
      >
        “
      </span>

      <div class="relative min-h-[180px]" data-anim="fade-up">
        {
          quotes.map((q, idx) => (
            <blockquote
              class="absolute inset-0 transition-opacity duration-500"
              x-show={`active === ${idx}`}
              x-transition.opacity.duration.500ms
            >
              <p class="font-display text-2xl leading-relaxed text-ink nav:text-3xl">
                {q.quote}
              </p>
              <footer class="mt-6 font-ui text-xs uppercase tracking-[0.28em] text-ink-muted">
                <span class="text-gradient">{q.author}</span> /{' '}
                <cite class="not-italic">{q.role}</cite>
              </footer>
            </blockquote>
          ))
        }
      </div>

      {/* Controls */}
      <div class="relative mt-10 flex items-center justify-center gap-6">
        <button
          type="button"
          class="grid h-10 w-10 place-items-center rounded-full border border-paper-gray text-ink-muted transition-colors hover:border-ink hover:text-ink"
          @click="prev()"
          aria-label="Previous testimonial"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="15 18 9 12 15 6" />
          </svg>
        </button>
        <ul class="flex items-center gap-2">
          {
            quotes.map((_, idx) => (
              <li>
                <button
                  type="button"
                  class="h-2 rounded-full transition-all"
                  :class={`active === ${idx} ? 'w-8 bg-gradient-accent' : 'w-2 bg-paper-gray hover:bg-ink-muted'`}
                  @click={`active = ${idx}`}
                  aria-label={`Go to testimonial ${idx + 1}`}
                />
              </li>
            ))
          }
        </ul>
        <button
          type="button"
          class="grid h-10 w-10 place-items-center rounded-full border border-paper-gray text-ink-muted transition-colors hover:border-ink hover:text-ink"
          @click="next()"
          aria-label="Next testimonial"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>
