---
import GradientText from '../atoms/GradientText.astro';

interface FooterColumn {
  title: string;
  links: { label: string; href: string }[];
}

interface SocialLink {
  label: string;
  href: string;
  icon: string;
}

interface Props {
  brand?: string;
  columns?: FooterColumn[];
  social?: SocialLink[];
  copyright?: string;
  signature?: string;
  legal?: { label: string; href: string }[];
}

const {
  brand = 'infinito',
  columns = [
    {
      title: 'about',
      links: [
        { label: 'the company', href: '#0' },
        { label: 'history', href: '#0' },
        { label: 'vision', href: '#0' },
        { label: 'team', href: '#0' },
      ],
    },
    {
      title: 'services',
      links: [
        { label: 'branding', href: '#0' },
        { label: 'web design', href: '#0' },
        { label: 'photography', href: '#0' },
        { label: 'print', href: '#0' },
      ],
    },
    {
      title: 'contact',
      links: [
        { label: 'map', href: '#0' },
        { label: 'basic info', href: '#0' },
        { label: 'Telegraphy!', href: '#0' },
        { label: 'contact form', href: '#contact' },
      ],
    },
    {
      title: 'get in touch',
      links: [
        { label: '7 Grell St, London SW6 6PP, UK', href: '#0' },
        { label: 'sprt@infinito.com', href: 'mailto:sprt@infinito.com' },
        { label: '+44 775 988 988', href: 'tel:+44775988988' },
      ],
    },
  ],
  social = [
    {
      label: 'Facebook',
      href: '#0',
      icon: 'M22 12.07C22 6.5 17.52 2 12 2S2 6.5 2 12.07c0 4.84 3.44 8.87 8 9.8v-6.93H7.9v-2.87H10V9.85c0-2.07 1.23-3.21 3.12-3.21.9 0 1.85.16 1.85.16v2.04h-1.04c-1.03 0-1.35.64-1.35 1.3v1.55h2.3l-.37 2.87h-1.93V21.9c4.56-.93 8-4.96 8-9.83Z',
    },
    {
      label: 'Twitter',
      href: '#0',
      icon: 'M22 5.92a8.2 8.2 0 0 1-2.36.66 4.13 4.13 0 0 0 1.8-2.27 8.18 8.18 0 0 1-2.6 1A4.1 4.1 0 0 0 11.85 9 11.65 11.65 0 0 1 3.4 4.6a4.1 4.1 0 0 0 1.27 5.47 4.1 4.1 0 0 1-1.85-.51v.05a4.1 4.1 0 0 0 3.29 4.02 4.1 4.1 0 0 1-1.85.07 4.1 4.1 0 0 0 3.83 2.85A8.23 8.23 0 0 1 2 18.13a11.61 11.61 0 0 0 6.29 1.84c7.55 0 11.68-6.25 11.68-11.67l-.01-.53A8.3 8.3 0 0 0 22 5.92Z',
    },
    {
