---

<footer id="footer" class="bg-ink text-paper">
  <div class="mx-auto max-w-[1440px] px-6 pb-10 pt-20 nav:px-12">
    <div class="grid gap-12 md:grid-cols-12">
      {/* Brand */}
      <div class="md:col-span-4 lg:col-span-5">
        <a href="#hero" class="inline-flex items-center gap-3">
          <svg
            class="h-12 w-12 text-paper"
            viewBox="0 0 100 100"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M39.213,35.87c-7.814-7.814-20.53-7.814-28.343,0C7.085,39.654,5,44.688,5,50.041s2.085,10.387,5.87,14.171c3.785,3.785,8.818,5.87,14.172,5.87c5.353,0,10.386-2.085,14.171-5.87L64.04,39.385l0.136-0.128c5.945-5.945,15.62-5.944,21.565,0.001c2.88,2.881,4.466,6.71,4.466,10.783c0,4.072-1.586,7.903-4.466,10.783c-2.879,2.879-6.71,4.465-10.782,4.465c-4.074,0-7.902-1.586-10.781-4.465l-5.671-5.653c-0.938-0.937-2.454-0.937-3.392,0c-0.936,0.938-0.936,2.454,0,3.393l6.067,6.043l0.011-0.001c3.733,3.536,8.603,5.477,13.766,5.477c5.354,0,10.387-2.085,14.171-5.87C92.916,60.428,95,55.395,95,50.041s-2.084-10.387-5.87-14.171C85.346,32.084,80.313,30,74.959,30c-4.995,0-9.714,1.816-13.352,5.09l-0.026-0.024L35.824,60.824c-2.881,2.879-6.71,4.465-10.783,4.465c-4.073,0-7.903-1.586-10.783-4.465c-2.879-2.88-4.466-6.711-4.466-10.785c0-4.073,1.585-7.903,4.466-10.783c5.946-5.945,15.621-5.944,21.566,0.001l5.713,5.722c0.938,0.935,2.453,0.935,3.392-0.001c0.937-0.937,0.937-2.453,0-3.391L39.213,35.87z"
            ></path>
          </svg>
          <span class="font-display text-2xl lowercase">{brand}</span>
        </a>
      </div>

      {/* Columns */}
      <div class="grid grid-cols-2 gap-10 md:col-span-8 md:grid-cols-4 lg:col-span-7">
        {
          columns.map((col) => (
            <div>
              <h5 class="mb-4 font-ui text-xs uppercase tracking-[0.28em] text-paper/60">
                {col.title}
              </h5>
              <ul class="space-y-2.5">
                {col.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="font-body text-sm text-paper/80 transition-colors hover:text-accent-text"
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <hr class="my-10 border-paper/10" />

    <div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-center">
      <a
        href="#hero"
        class="group inline-flex items-center gap-2 font-ui text-xs uppercase tracking-[0.28em] text-paper/70 transition-colors hover:text-paper"
      >
        <span>Back to top</span>
        <span class="inline-block translate-y-0 transition-transform group-hover:-translate-y-0.5">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="18 15 12 9 6 15"></polyline>
          </svg>
        </span>
      </a>

      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 font-ui text-xs uppercase tracking-[0.18em] text-paper/60">
        <span>{copyright}</span>
        {legal.map((l) => (
          <a href={l.href} class="hidden hover:text-paper sm:inline">{l.label}</a>
        ))}
        <span>
          {signature.split(/care/i)[0]}
          <GradientText>care</GradientText>
          {signature.split(/care/i)[1]}
        </span>
      </div>

      <div class="flex items-center gap-3">
        {
          social.map((s) => (
            <a
              href={s.href}
              aria-label={s.label}
              class="grid h-9 w-9 place-items-center rounded-full border border-paper/15 text-paper/80 transition-all hover:border-transparent hover:bg-gradient-accent hover:text-paper"
            >
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d={s.icon} />
              </svg>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
